{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "gravitymd",
  "version": "1.0.3",
  "identifier": "com.gravity.markdown",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Gravity Markdown",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "Markdown",
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
